{
  "name": "openagent",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, cross-platform agentic AI IDE with MCP/Skills/Marketplace support and provider-agnostic adapters.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "node --test packages/agent-harness/test packages/adapters/test packages/cli/test",
    "lint": "node ci/lint.js",
    "index": "node packages/cli/src/cli.js index .",
    "validate": "node packages/cli/src/cli.js validate microtasks/example_manifest.json"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/versangil/OpenAgent"
  }
}
